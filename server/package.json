{
  "name": "project_manager",
  "version": "1.0.0",
  "description": "a site to track and organize projects,tasks assignments with comment support",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon index.js",
    "prod": "node index.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "postinstall": "prisma generate",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check-format": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:pull": "prisma db pull",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "npx prisma migrate reset --force"
  },
  "author": "chirayu dodiya",
  "license": "ISC",
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "etag": "^1.8.1",
    "express": "^5.2.1",
    "ioredis": "^5.11.1",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.5.2",
    "node-cron": "^4.4.1",
    "prisma": "^7.8.0",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
